> nameEx("bar_plot")
> ### * bar_plot
> 
> flush(stderr()); flush(stdout())
> 
> ### Name: bar_plot
> ### Title: Get a bar plot for flagging percentage overall and stratified by
> ###   provider sizes
> ### Aliases: bar_plot
> 
> ### ** Examples
> 
> data(ExampleDataLinear)
> outcome <- ExampleDataLinear$Y
